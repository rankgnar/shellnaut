# Authentication — run "npm run setup" to configure
# AUTH_USER=your-username
# AUTH_HASH=salt:hash

# Server port
PORT=3001

# Bind address — set to your Tailscale IP to block public access
# HOST=100.x.x.x

# Default shell command
DEFAULT_CMD=bash

# Max concurrent sessions
MAX_SESSIONS=10

# Allowed commands (comma-separated)
ALLOWED_COMMANDS=bash,sh,zsh,claude,gemini,codex,opencode,aider,node,python3

# Inactivity timeout in minutes (sessions auto-killed after this)
INACTIVITY_TIMEOUT=30

# Optional: restrict WebSocket connections to specific origins (comma-separated)
# ALLOWED_ORIGINS=https://your-domain.com
